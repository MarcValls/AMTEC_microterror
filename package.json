{
  "name": "amtec_microterror",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "setup:local": "bash ./scripts/setup_local_env.sh",
    "checklist:local": "bash ./scripts/run_local_deploy_checklist.sh",
    "stop:local": "bash ./scripts/stop_local_deploy.sh",
    "tu:flipao:inicia:app": "bash ./scripts/tu_flipao_inicia_la_app.sh",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dev:api": "bash ./scripts/start_api_local.sh",
    "dev:web": "bash ./scripts/start_web_local.sh",
    "dev:web:raw": "pnpm --filter @amtec/web dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
